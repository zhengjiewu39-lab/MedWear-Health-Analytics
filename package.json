{
  "name": "medwear-health-analytics",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^5.15.12",
    "@mui/material": "^5.15.12",
    "adm-zip": "^0.5.16",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "multer": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "sax": "^1.4.1",
    "web-vitals": "^5.3.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "free-ports": "node scripts/free-ports.js",
    "stop": "node scripts/free-ports.js",
    "dev": "node scripts/dev.js",
    "test:server": "node --test server/__tests__/*.test.js",
    "evaluate": "node scripts/evaluate-analytics.js",
    "generate:cohort": "node scripts/generate-screening-cohort.js",
    "evaluate:outcomes": "node scripts/evaluate-screening-outcomes.js",
    "validate:cohort": "node scripts/validate-clinical-cohort.js",
    "export:features": "node scripts/export_features.js",
    "generate:synth-health": "node scripts/generate_synthetic_healthdata.js --users 200 --days 14",
    "experiment:export": "npm run export:features",
    "experiment:train": "python experiments/medwear/train.py --data experiments/data/medwear/features_v1.csv --model rf --cv 5 --seed 42",
    "experiment:summary": "python experiments/medwear/evaluate.py --results experiments/results --out experiments/results/summary.csv"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "proxy": "http://localhost:3001",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "react-scripts": "^5.0.1"
  }
}
