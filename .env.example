# Environment variables (copy to .env for local development)

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
# Dev default is 5000/15min; production default is 300. Set RATE_LIMIT_DEV=off to disable in dev.
RATE_LIMIT_MAX=5000

# Auth — required in production
MEDWEAR_JWT_SECRET=change-me-in-production
MEDWEAR_ENCRYPTION_KEY=change-me-32-chars-minimum-secret

# Demo-only (disabled when ALLOW_DEMO_AUTH=false)
ALLOW_DEMO_AUTH=true
MEDWEAR_ADMIN_PASSWORD=
MEDWEAR_DEMO_PASSWORD=

# Optional OpenAI (real mode AI)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
