# Environment variables (copy to .env for local development)

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
# Dev default is 5000/15min; production default is 300. Set RATE_LIMIT_DEV=off to disable in dev.
RATE_LIMIT_MAX=5000

# Auth — required in production
MEDWEAR_JWT_SECRET=change-me-in-production
MEDWEAR_ENCRYPTION_KEY=change-me-32-chars-minimum-secret

# Demo-only (disabled when ALLOW_DEMO_AUTH=false)
ALLOW_DEMO_AUTH=true
MEDWEAR_ADMIN_PASSWORD=

# Optional AI providers (demo + real modes use live LLM when configured)
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# GROK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# MEDWEAR_AI_API_KEY=   # fallback for any provider

# Exam booking — real-mode nearby facility search (IP geolocation + OpenStreetMap Overpass)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# OVERPASS_TIMEOUT_MS=12000
# DISABLE_LIVE_HOSPITALS=0
